    <!-- Mosh setup guide dialog -->
    <string name="connections_mosh_not_found_title">सर्वर पर Mosh नहीं मिला</string>
    <string name="connections_mosh_not_found_message">रिमोट होस्ट पर mosh-server इंस्टॉल नहीं है। Mosh (Mobile Shell) नेटवर्क बदलने और उच्च विलंबता कनेक्शन पर आपका सत्र सक्रिय रखता है।</string>
    <string name="connections_mosh_install_prompt">सर्वर पर इंस्टॉल करें:</string>
    <string name="connections_mosh_install_commands">\u0020 Ubuntu/Debian:  sudo apt install mosh\n\u0020 Fedora/RHEL:    sudo dnf install mosh\n\u0020 Arch:           sudo pacman -S mosh\n\u0020 macOS:          brew install mosh</string>
    <string name="connections_mosh_firewall_note">सर्वर फ़ायरवॉल पर UDP पोर्ट 60001 खुला होना चाहिए।</string>
    <string name="connections_mosh_github">Mosh on GitHub</string>

